vpc_existing_redis_subnets              = [ "10.0.6.0/24" ]

# Must be >= 2, in different AZs. Ensure only public subnets (nothing needs to be in these).
vpc_existing_alb_subnets                = [ "10.0.1.0/24", "10.0.2.0/24" ]

/*
