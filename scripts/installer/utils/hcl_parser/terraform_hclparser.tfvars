seqerakit_org_url                       = "https://www.example.com"

seqerakit_team_name                     = "SampleTeam_schaluva"
seqerakit_team_members                  = "sushma.chaluvadi@seqera.io, esha.joshi@seqera.io" #,graham.wright@seqera.io"

